[user]
	name = Akira Maruoka
	email = akmaru0266@gmail.com

[core]
	editor = nvim
	excludesfile = "~/.gitignore"

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true


[include]
	path = ~/.gitconfig_os

[includeIf "hasconfig:remote.*.url:git@github.com:Maru0137/**"]
	path = ~/.gitconfig_dqrta

[include]
	path = ~/.work.gitconfig
