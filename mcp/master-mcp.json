{
  "_comment": "MCP master configuration - edit this file and run sync-mcp.sh to propagate",
  "servers": {
    "GitHub": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      },
      "_comment": "GitHub MCP server - Local Docker (Official)"
    },
    "GitLab": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://gitlab.com/api/v4/mcp",
        "--static-oauth-client-metadata",
        "{\"scope\": \"mcp\"}"
      ]
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "env": {
        "MEMORY_FILE": "${HOME}/.config/mcp/shared-memory.json"
      },
      "_comment": "Shared memory server - knowledge graph shared across all tools"
    },
    "drawio": {
      "command": "npx",
      "args": [
        "@drawio/mcp"
      ]
    }
  }
}
